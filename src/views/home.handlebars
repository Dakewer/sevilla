<div class="container bg-white shadow-lg my-5 p-0">
    <header class="row g-0 bg-primary text-white p-4 align-items-center">
        <div class="col-md-9 ps-md-4">
            <button type="button" class="btn btn-light" data-toggle="modal" data-target="#login">
                <i class="bi bi-plus-circle"></i> New Student
            </button>
        </div>
    </header>

    <div class="row g-0">
        <div class="col-12 p-4">
            <h2 class="h4 border-bottom pb-2 mb-3">Lista de Estudiantes</h2>
            <table class="table table-striped">
                <thead class="thead-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Expediente</th>
                    <th>Semestre</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody id="studentTableBody">
                {{#each students}}
                    <tr>
                        <td>{{this.name}}</td>
                        <td>{{this.mail}}</td>
                        <td>{{this.expedient}}</td>
                        <td>{{this.semester}}</td>
                        <td>
                            <button class="btn btn-sm btn-primary" onclick="editStudent('{{this.expedient}}')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteStudent('{{this.expedient}}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>