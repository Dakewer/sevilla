<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Chrono Quest</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="icon" href="https://i.pinimg.com/736x/91/b7/0f/91b70f06458fe3332ef73e00f53385e6.jpg">
</head>

<body>
<!-- Navar normal -->
<nav class="navbar navbar-expand-md navbar-dark d-none d-md-flex sticky-top custom-nav">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <img src="https://img.freepik.com/vector-premium/icono-espada-videojuego-pixeles-espadas-cruzadas-arma-caballero-ilustracion-vectorial-estilo-retro_168129-1503.jpg"
                 alt="Logo" width="30" height="30" class="me-2">
            Cronos Quest
        </a>

        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="navbar-nav ms-auto">
                <a class="nav-link active" href="/"><i class="bi bi-house-fill"></i> Home</a>
                <a class="nav-link" href="/calendar"><i class="bi bi-calendar"></i> Calendar</a>
                <a class="nav-link" href="/add"><i class="bi bi-plus-circle"></i> Add</a>
                <a class="nav-link" href="/todo"><i class="bi bi-clipboard-check"></i> Todo</a>
                <a class="nav-link" href="/clan"><i class="bi bi-shield-fill"></i> Clan</a>

                <div class="nav-item dropdown ms-md-3">
                    <a class="nav-link dropdown-toggle btn btn-outline-light btn-sm text-white" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle"></i> Mi Héroe
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="profileDropdown">
                        <li><a class="dropdown-item nav-link text-black" href="/profile">Perfil</a></li>
                        <li><a class="dropdown-item nav-link text-black" href="/settings">Configuración</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/login">Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</nav>

<nav class="navbar navbar-dark fixed-top d-md-none custom-nav">
    <div class="container-fluid">
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <a href="/" class="navbar-brand mx-auto">Cronos Quest</a>
        <a href="#" class="text-white">
            <i class="bi bi-bell-fill" style="font-size: 1.5rem;"></i>
        </a>
    </div>
</nav>

<!-- Aqui se pinta la info -->
<main class="container py-4">
    {{{body}}}
</main>

<!-- Barra inferior -->
<nav class="navbar fixed-bottom d-md-none border-top bottom-nav">
    <div class="container-fluid d-flex justify-content-around">
        <a href="#" class="nav-item-mobile active">
            <i class="bi bi-house-door-fill"></i>
            <span>Home</span>
        </a>
        <a href="#" class="nav-item-mobile">
            <i class="bi bi-calendar-event"></i>
            <span>Calendar</span>
        </a>
        <a href="#" class="nav-item-mobile add-btn">
            <i class="bi bi-plus-circle"></i>
            <span>Add</span>
        </a>
        <a href="#" class="nav-item-mobile">
            <i class="bi bi-clipboard-check"></i>
            <span>To do</span>
        </a>
        <a href="#" class="nav-item-mobile">
            <i class="bi bi-shield-fill"></i>
            <span>Clan</span>
        </a>
    </div>
</nav>

<!-- menu de hamburgesa, aqui ira toda la info del pj -->
<div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="offcanvasMenu">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">Menú de Héroe</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <ul class="list-unstyled">
            <li><a href="#" class="text-white text-decoration-none d-block py-2">Perfil</a></li>
            <li><a href="#" class="text-white text-decoration-none d-block py-2">Configuración</a></li>
            <hr>
            <li><a href="#" class="text-danger text-decoration-none d-block py-2">Cerrar Sesión</a></li>
        </ul>
    </div>
</div>

<!-- Bostrap -->
<script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
