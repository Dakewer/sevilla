<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Colegio</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="icon" href="https://static.wixstatic.com/media/61dbaa_67f044d8234e4402a1738ed56861cbda~mv2.png/v1/fit/w_2500,h_1330,al_c/61dbaa_67f044d8234e4402a1738ed56861cbda~mv2.png">
</head>

<body>
<nav class="navbar navbar-dark bg-dark mb-4">
    <span class="navbar-brand mb-0 h1 px-3">Sistema Escolar</span>
</nav>

<div class="modal fade" id="login" tabindex="-1" role="dialog" aria-labelledby="modelTitleId" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Registrar Nuevo Alumno</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form action="/students/add" method="POST">

                    <div class="form-group mb-3">
                        <label for="name">Nombre Completo</label>
                        <div class="input-group">
                            <input type="text" class="form-control" name="name" id="name" placeholder="Ej. Juan Pérez" required>
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label for="mail">Correo Electrónico</label>
                        <div class="input-group">
                            <input type="email" class="form-control" name="mail" id="mail" placeholder="correo@ejemplo.com" required>
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label for="expedient">Número de Expediente</label>
                        <div class="input-group">
                            <input type="number" class="form-control" name="expedient" id="expedient" placeholder="123456" required>
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="bi bi-hash"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label for="semester">Semestre</label>
                        <div class="input-group">
                            <input type="number" class="form-control" name="semester" id="semester" min="1" max="10" placeholder="1-10" required>
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="bi bi-mortarboard-fill"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group d-flex justify-content-center mt-4">
                        <button type="submit" class="btn btn-success" style="width: 90%;">Registrar Alumno</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<main class="container py-4">
    {{{body}}}
</main>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>